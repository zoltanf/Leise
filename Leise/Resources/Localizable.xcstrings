    "When context X is detected, Leise uses behavior Y.": {
      "extractionState": "stale",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンテキストXが検出されると、Leiseは動作Yを使用します。"
          }
        }
      }
    },
    "When disabled, Leise skips live transcript requests for the indicator and only runs the final transcription after you stop recording.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効にすると、Leiseはインジケーター用のライブテキストリクエストをスキップし、録音を停止した後にのみ最終的なテキスト生成が実行されます。"
          }
        }
      }
    },
    "When disabled, the indicator only shows recording status while transcription continues in the background.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deaktiviert, zeigt der Indikator nur den Aufnahmestatus an, während die Transkription im Hintergrund weiterläuft."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無効にすると、インジケーターは録音状態のみを表示し、背景でのテキスト生成は継続されます。"
          }
        }
      }
    },
    "When hidden, the app is accessible via the Dock icon.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn ausgeblendet, ist die App über das Dock-Symbol erreichbar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非表示にすると、アプリはドックのアイコンを通じてアクセス可能になります。"
          }
        }
      }
    },
    "When hidden, the app stays accessible via the Dock icon.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn ausgeblendet, bleibt die App über das Dock-Symbol erreichbar."
