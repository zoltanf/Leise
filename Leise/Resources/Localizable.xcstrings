          }
        }
      }
    },
    "This engine currently uses Dictionary Corrections only.": {
      "comment": "Text displayed in a detail label for a dictionary engine that currently uses only dictionary corrections.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このエンジンは現在、辞書修正のみを使用しています。"
          }
        }
      }
    },
    "This engine does not support multiple language hints. It will use #1 as the spoken language.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Engine unterstützt keine mehreren Sprachhinweise. Sie verwendet Nr. 1 als gesprochene Sprache."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このエンジンは複数の言語ヒントに対応していません。1番目を話す言語として使います。"
          }
        }
      }
    },
    "This engine needs an extra setting before Terms are applied.": {
      "comment": "Tooltip text for the extra component setting required for the Terms feature.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
