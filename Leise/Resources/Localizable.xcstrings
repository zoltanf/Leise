    "Leise can watch the target text field briefly after direct dictation insertion and learn only confident corrections. Ambiguous edits are skipped.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leise kann das Ziel-Textfeld kurz nach direktem Diktat-Einfügen beobachten und nur sichere Korrekturen lernen. Uneindeutige Bearbeitungen werden übersprungen."
          }
        }
      }
    },
    "Leise Dev": {
