{
  "language": "en",
  "rules": [
    { "phrase": "question mark", "replacement": "?", "category": "punctuation" },
    { "phrase": "exclamation mark", "replacement": "!", "category": "punctuation" },
    { "phrase": "colon", "replacement": ":", "category": "punctuation" },
    { "phrase": "semicolon", "replacement": ";", "category": "punctuation" },
    { "phrase": "open parenthesis", "replacement": "(", "category": "brackets" },
    { "phrase": "close parenthesis", "replacement": ")", "category": "brackets" },
    { "phrase": "open bracket", "replacement": "(", "category": "brackets" },
    { "phrase": "close bracket", "replacement": ")", "category": "brackets" },
    { "phrase": "comma", "replacement": ",", "category": "punctuation" },
    { "phrase": "period", "replacement": ".", "category": "punctuation" },
    { "phrase": "full stop", "replacement": ".", "category": "punctuation" }
  ],
  "verificationScenarios": [
    { "spoken": "hello comma world", "expected": "hello, world" },
    { "spoken": "how are you question mark", "expected": "how are you?" },
    { "spoken": "hello open parenthesis test close parenthesis", "expected": "hello (test)" },
    { "spoken": "warning exclamation mark", "expected": "warning!" },
    { "spoken": "title colon example", "expected": "title: example" }
  ]
}
