// Leise Code Signing Configuration
//
// To use your own signing identity, create CodeSigning.local.xcconfig:
//   echo 'DEVELOPMENT_TEAM = YOUR_TEAM_ID' > CodeSigning.local.xcconfig
//
// Find your Team ID: Xcode > Settings > Accounts > select team

#include? "CodeSigning.local.xcconfig"
APP_GROUP_ID = $(DEVELOPMENT_TEAM).com.leise.mac
