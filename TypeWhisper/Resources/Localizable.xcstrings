    "Thank you for supporting TypeWhisper! Join our Discord to claim your supporter role.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Danke für deine Unterstützung! Tritt unserem Discord bei, um deine Supporter-Rolle zu erhalten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ご支援ありがとうございます！Discordに参加してサポート者ロールを取得してください。"
          }
        }
      }
    },
    "The file contains no dictionary entries.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Datei enthält keine Wörterbuch-Einträge."
          }
