    "Auto-unload model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modell automatisch entladen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルを自動でアンロード"
          }
        }
      }
    },
    "Automatically extracts facts, preferences and patterns from your transcriptions using an LLM. Memories are injected into prompt context.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Extrahiert automatisch Fakten, Präferenzen und Muster aus deinen Transkriptionen per LLM. Erinnerungen werden als Kontext in Prompts eingefügt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LLMを使用して、あなたの転写テキストから事実、好み、パターンを自動的に抽出します。思い出はプロンプトのコンテキストとして挿入されます。"
          }
        }
      }
    },
    "When enabled, TypeWhisper uses target-app rules and available cursor context for smarter insertion. Workflow output format settings still choose the inserted format for each workflow.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, nutzt TypeWhisper Regeln der Ziel-App und verfügbaren Cursor-Kontext für intelligenteres Einfügen. Die Ausgabeformat-Einstellungen des Workflows bestimmen weiterhin das eingefügte Format für jeden Workflow."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、TypeWhisper は対象アプリのルールと利用可能なカーソルの文脈を使って、よりスマートに挿入します。ワークフローの出力形式設定は、各ワークフローで挿入する形式を引き続き決定します。"
          }
        }
      }
    },
    "Automatically pauses music and videos while recording and resumes when done. Uses macOS system media controls - may not work with all apps.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausiert automatisch Musik und Videos während der Aufnahme und setzt die Wiedergabe fort, wenn fertig. Verwendet macOS-Systemsteuerung - funktioniert möglicherweise nicht mit allen Apps."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音中に自動的に音楽や動画を一時停止し、録音が完了すると再生を再開します。macOSのシステムコントロールを使用 - すべてのアプリで動作するとは限りません。"
          }
        }
      }
    },
    "Automatically press Enter after inserting text. In chat apps this sends the message, in editors it adds a new line.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drückt nach dem Einfügen automatisch Enter. In Chat-Apps wird die Nachricht gesendet, in Editoren eine neue Zeile eingefügt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "挿入後自動的にEnterを押します。チャットアプリではメッセージが送信され、エディタでは新しい行が挿入されます。"
          }
        }
      }
    },
    "Automatically unloads local models from memory after inactivity. It reloads when needed. Does not affect cloud engines.": {
      "localizations": {
        "de": {
          "stringUnit": {
