    "Are you sure you want to uninstall %@? This will remove the plugin and its data.": {
      "comment": "A message in an alert that appears when a user attempts to uninstall a plugin. The argument is the name of the plugin that is being uninstalled.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchtest du %@ wirklich deinstallieren? Das Plugin und seine Daten werden entfernt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当に%@をアンインストールしますか？プラグインとそのデータが削除されます。"
          }
        }
      }
    },
    "Assign a hotkey to always use this profile, regardless of the active app.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Weisen Sie ein Tastenkürzel zu, um dieses Profil immer zu verwenden, unabhängig von der aktiven App."
