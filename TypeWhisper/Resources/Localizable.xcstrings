        }
      }
    },
    "Activate or buy a license to start writing sync files.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere oder kaufe eine Lizenz, damit Sync-Dateien geschrieben werden können."
          }
        },
        "ja": {
