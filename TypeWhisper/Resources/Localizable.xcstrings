    "Fast, private speech-to-text for your Mac. Transcribe with local or cloud engines, process text with AI prompts, and insert directly into any app." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schnelle, private Sprache-zu-Text-Erkennung für deinen Mac. Transkribiere mit lokalen oder Cloud-Engines, verarbeite Text mit KI-Prompts und füge ihn direkt in jede App ein."
          }
        }
      }
