    "Terms + Corrections": {
      "comment": "Badge text for a dictionary engine support row.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "用語 + 修正"
