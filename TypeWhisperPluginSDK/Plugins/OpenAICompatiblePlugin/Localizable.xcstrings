{
  "sourceLanguage": "en",
  "strings": {
    "API Key": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキー"
          }
        }
      }
    },
    "API keys are stored securely in the Keychain": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API-Schlüssel werden sicher im Schlüsselbund gespeichert"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "APIキーはセキュアにキーチェーンに保存されます"
          }
        }
      }
    },
    "Connected": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbunden"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続済み"
          }
        }
      }
    },
    "Connection Failed": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindung fehlgeschlagen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続失敗"
          }
        }
      }
    },
    "e.g. http://localhost:11434": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "z.B. http://localhost:11434"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "例: http://localhost:11434"
          }
        }
      }
    },
    "LLM Model": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "LLM-Modell"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LLMモデル"
          }
        }
      }
    },
    "LLM Request Timeout": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeitlimit für LLM-Anfrage"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LLMリクエストのタイムアウト"
          }
        }
      }
    },
    "Thinking Mode": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Denkmodus"
          }
        },
        "en": {
